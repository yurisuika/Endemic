{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",

  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "homepage": "https://${mod_author}.dev",
    "sources": "https://github.com/${mod_author}/${mod_name}",
    "issues": "https://github.com/${mod_author}/${mod_name}/issues"
  },

  "license": "${mod_license}",
  "icon": "icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "${mod_group}.${mod_name}"
    ],
    "fabric-datagen": [
      "${mod_group}.${mod_name}\$Data"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],

  "accessWidener": "${mod_id}.accesswidener",

  "depends": {
    "fabricloader": "${loader_version_range}",
    "minecraft": "${minecraft_version_range}",
    "java": ">=${java_version}"
  },
  "suggests": {
    "fabric": "${api_version_range}",
    "fabric-api": "${api_version_range}"
  }
}